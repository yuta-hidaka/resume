---
import Layout from '../../layouts/Layout.astro';
import { getData } from '../../data/about.ja';

const data = getData('en');
const current = data.experience?.[0];
---

<Layout>
  <section class="pt-14 md:pt-20 pb-10 md:pb-14">
    <p class="section-label">Software Engineer — Tokyo</p>
    <h1 class="name-display font-display mt-4">{data.given_name} {data.family_name}</h1>
    <p class="font-display text-lg text-[var(--ink-muted)] mt-2" lang="ja">日髙 悠太</p>
    <p class="text-[var(--ink-secondary)] mt-6">{data.profession}</p>
  </section>

  <hr class="rule" />

  <section class="py-10 md:py-14 grid gap-10 md:grid-cols-[minmax(0,1fr)_200px] md:gap-16 items-start">
    <figure class="portrait md:order-2">
      <img
        src="/me.jpeg"
        alt={`${data.given_name} ${data.family_name}`}
        width="384"
        height="480"
        loading="eager"
      />
    </figure>

    <div class="md:order-1">
      <p class="text-[var(--ink-secondary)] leading-loose">{data.bio}</p>

      <dl class="mt-10 grid grid-cols-[auto_1fr] gap-x-8 gap-y-2 text-sm">
        {current && (
          <>
            <dt class="text-[var(--ink-muted)]">Currently</dt>
            <dd>{current.company} — {current.jobTitle}</dd>
          </>
        )}
        <dt class="text-[var(--ink-muted)]">Based in</dt>
        <dd>{data.address}</dd>
      </dl>

      {data.social && (
        <ul class="mt-10 flex flex-wrap gap-x-7 gap-y-2 text-sm">
          {data.social.map((social) => (
            <li>
              <a href={social.url} target="_blank" rel="noopener noreferrer" class="text-link">
                {social.name} ↗
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>
</Layout>

<style>
  .name-display {
    font-size: clamp(2.75rem, 9vw, 4.25rem);
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: -0.015em;
  }

  .portrait {
    width: 200px;
    padding: 0.4rem;
    border: 1px solid var(--line);
    background: var(--paper-raised);
  }

  .portrait img {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
  }
</style>
