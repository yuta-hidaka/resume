---
import Layout from '../../layouts/Layout.astro';
import DocumentSection from '../../components/DocumentSection.astro';
---

<Layout title="CV Download - Yuta Hidaka">
  <header class="pt-14 md:pt-20 pb-10">
    <p class="section-label">Downloads</p>
    <h1 class="page-title mt-3">CV &amp; Resume</h1>
  </header>

  <DocumentSection
    id="en-resume"
    title="Resume (English)"
    sourcePath="docs/resume/resume-en.md"
    downloadFileName="yuta-hidaka-resume-en.pdf"
    previewHeight="750px"
    isMarkdown={true}
    staticPdfUrl="/pdf/yuta-hidaka-resume-en.pdf"
  />

  <DocumentSection
    id="en-cv"
    title="CV (English)"
    sourcePath="docs/resume/en-cv.html"
    assetBase="/docs/resume/en-cv/"
    downloadFileName="yuta-hidaka-cv-en.pdf"
    previewHeight="750px"
    staticPdfUrl="/pdf/yuta-hidaka-cv-en.pdf"
  />
</Layout>
