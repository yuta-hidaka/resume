---
import Layout from '../../layouts/Layout.astro';
import DocumentSection from '../../components/DocumentSection.astro';
import { renderCareerMarkdown } from '../../lib/docs/career-markdown';
import { renderCareerHtml } from '../../lib/docs/career-html';
import { toHtmlDocument } from '../../lib/docs/html';
import { downloadFileName } from '../../lib/docs/filenames';
---

<Layout title="CV Download - Yuta Hidaka">
  <header class="pt-14 md:pt-20 pb-10">
    <p class="section-label">Downloads</p>
    <h1 class="page-title mt-3">CV &amp; Resume</h1>
  </header>

  <DocumentSection
    id="en-resume"
    title="Resume (English)"
    sourceMarkdown={renderCareerMarkdown('en')}
    downloadFileName={downloadFileName('resume-text', 'en')}
    previewHeight="750px"
    staticPdfUrl="/pdf/yuta-hidaka-resume-en.pdf"
  />

  <DocumentSection
    id="en-cv"
    title="CV (English)"
    sourceHtml={toHtmlDocument(renderCareerHtml('en'))}
    downloadFileName={downloadFileName('cv', 'en')}
    previewHeight="750px"
    staticPdfUrl="/pdf/yuta-hidaka-cv-en.pdf"
  />
</Layout>
