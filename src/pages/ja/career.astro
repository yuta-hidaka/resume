---
import Layout from '../../layouts/Layout.astro';
import HistoryCard from '../../components/HistoryCard.astro';
import { getData } from '../../data/about.ja';

const data = getData('ja');
---

<Layout title="キャリア - 日髙悠太">
  <header class="pt-14 md:pt-20 pb-10">
    <p class="section-label">Career</p>
    <h1 class="page-title mt-3">職務経歴</h1>
  </header>

  <section>
    {data.experience && data.experience.map((exp, i) => (
      <HistoryCard
        company={exp.company}
        startDate={exp.startDate}
        endDate={exp.endDate}
        jobTitle={exp.jobTitle}
        job={exp.projects.job}
        jobDescription={exp.projects.jobDescription}
        tags={exp.projects.tags || []}
        index={i}
        locale="ja"
      />
    ))}
  </section>
</Layout>
