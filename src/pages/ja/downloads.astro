---
import Layout from '../../layouts/Layout.astro';
import DocumentSection from '../../components/DocumentSection.astro';
import { renderCareerMarkdown } from '../../lib/docs/career-markdown';
import { renderCareerHtml } from '../../lib/docs/career-html';
import { renderRirekisho } from '../../lib/docs/rirekisho';
import { toHtmlDocument } from '../../lib/docs/html';
import { downloadFileName } from '../../lib/docs/filenames';
---

<Layout title="履歴書ダウンロード - 日髙悠太">
  <header class="pt-14 md:pt-20 pb-10">
    <p class="section-label">Downloads</p>
    <h1 class="page-title mt-3">履歴書・職務経歴書</h1>
  </header>

  <DocumentSection
    id="jp-resume-md"
    title="レジュメ（テキスト）"
    sourceMarkdown={renderCareerMarkdown('ja')}
    downloadFileName={downloadFileName('resume-text', 'ja')}
    previewHeight="750px"
    staticPdfUrl="/pdf/yuta-hidaka-resume-ja-text.pdf"
  />

  <DocumentSection
    id="jp-cv"
    title="職務経歴書"
    sourceHtml={toHtmlDocument(renderCareerHtml('ja'))}
    downloadFileName={downloadFileName('cv', 'ja')}
    previewHeight="750px"
    staticPdfUrl="/pdf/yuta-hidaka-cv-ja.pdf"
  />

  <DocumentSection
    id="jp-resume"
    title="履歴書"
    sourceHtml={toHtmlDocument(renderRirekisho())}
    downloadFileName={downloadFileName('rirekisho', 'ja')}
    previewHeight="750px"
    staticPdfUrl="/pdf/yuta-hidaka-resume-ja.pdf"
  />
</Layout>
