---
import { marked } from 'marked';
import { renderCareerHtml } from '../../../lib/docs/career-html';
import { renderCareerMarkdown } from '../../../lib/docs/career-markdown';
import { renderRirekisho } from '../../../lib/docs/rirekisho';
import { MARKDOWN_DOC_CSS } from '../../../lib/docs/markdown-css';

export function getStaticPaths() {
  return [
    { params: { documentId: 'jp-resume-md' } },
    { params: { documentId: 'jp-cv' } },
    { params: { documentId: 'jp-resume' } },
  ];
}

const { documentId } = Astro.params;

// All documents are generated from the canonical profile
// (src/data/profile/profile.ts) — no static doc files involved.
let doc = null;
let markdownHtml = null;
if (documentId === 'jp-cv') doc = renderCareerHtml('ja');
if (documentId === 'jp-resume') doc = renderRirekisho();
if (documentId === 'jp-resume-md') markdownHtml = marked.parse(renderCareerMarkdown('ja'));
---

{doc ? (
  <html lang="ja">
    <head>
      <meta charset="utf-8" />
      <meta name="viewport" content="width=device-width" />
      <meta name="robots" content="noindex" />
      <title>PDF - {doc.title}</title>
      <style set:html={doc.css}></style>
    </head>
    <body class={doc.bodyClass} set:html={doc.bodyHtml}></body>
  </html>
) : markdownHtml ? (
  <html lang="ja">
    <head>
      <meta charset="utf-8" />
      <meta name="viewport" content="width=device-width" />
      <meta name="robots" content="noindex" />
      <title>PDF - レジュメ（テキスト）</title>
      <style set:html={MARKDOWN_DOC_CSS}></style>
    </head>
    <body class="md-doc" set:html={markdownHtml}></body>
  </html>
) : (
  <html lang="ja">
    <head>
      <meta charset="utf-8" />
      <title>Not Found</title>
    </head>
    <body>Document not found: {documentId}</body>
  </html>
)}
