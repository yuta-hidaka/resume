---
import Layout from '../../layouts/Layout.astro';
import { getData } from '../../data/about.ja';

const data = getData('ja');

function formatDate(dateStr: string): string {
  if (!dateStr) return '現在';
  const [year, month] = dateStr.split('-');
  return month ? `${year}.${month}` : year;
}
---

<Layout title="アバウト - 日髙悠太">
  <header class="pt-14 md:pt-20 pb-10">
    <p class="section-label">Profile</p>
    <h1 class="page-title mt-3">アバウト</h1>
  </header>

  <!-- Education -->
  <section class="about-section glass">
    <h2 class="section-label">Education</h2>
    <div class="mt-7 space-y-8">
      {data.education && data.education.map((edu) => (
        <div class="entry-grid">
          <p class="entry-dates tnum">{formatDate(edu.startDate)} — {formatDate(edu.endDate)}</p>
          <div class="min-w-0">
            <h3 class="font-display text-xl font-semibold text-[var(--ink)]">{edu.institution}</h3>
            <p class="text-sm text-[var(--ink-muted)] mt-1">{edu.degree}</p>
            <p class="text-[var(--ink-secondary)] mt-3">{edu.description}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Motivation -->
  <section class="about-section glass">
    <h2 class="section-label">Motivation</h2>
    <ol class="mt-7 space-y-8">
      {data.motivation && data.motivation.map((item, i) => (
        <li class="motivation-item">
          <span class="motivation-num font-display tnum">{i + 1}.</span>
          <div class="min-w-0">
            <h3 class="font-medium text-[var(--ink)]">{item.title}</h3>
            <p class="text-[var(--ink-secondary)] mt-2">{item.desc}</p>
          </div>
        </li>
      ))}
    </ol>
  </section>

  <!-- Personal Projects -->
  <section class="about-section glass">
    <h2 class="section-label">Personal Projects</h2>
    <ul class="mt-7 space-y-7">
      {data.selfProject && data.selfProject.map((project) => (
        <li>
          {project.link ? (
            <a href={project.link} target="_blank" rel="noopener noreferrer" class="text-link font-medium">
              {project.title} ↗
            </a>
          ) : (
            <span class="font-medium text-[var(--ink)]">{project.title}</span>
          )}
          <p class="text-sm text-[var(--ink-muted)] mt-1.5">{project.desc}</p>
        </li>
      ))}
    </ul>
  </section>

  <!-- Languages -->
  <section class="about-section glass">
    <h2 class="section-label">Languages</h2>
    <ul class="mt-7 space-y-2">
      {data.skills?.LanguageSkills.map((skill) => (
        <li class="skill-row">
          <span class="text-[var(--ink)] font-medium">{skill.name}</span>
          <span class="leader" aria-hidden="true"></span>
          <span class="text-sm text-[var(--ink-muted)]">{skill.description}</span>
        </li>
      ))}
    </ul>
  </section>

  <!-- Technical Skills -->
  <section class="about-section glass">
    <h2 class="section-label">Technical Skills</h2>
    <ul class="mt-7 md:columns-2 md:gap-x-12">
      {data.skills?.ProgrammingSkills.map((skill) => (
        <li class="skill-item">
          <span class="skill-row">
            <span class="text-[var(--ink)] font-medium">{skill.name}</span>
            <span class="leader" aria-hidden="true"></span>
            <span class="text-sm text-[var(--ink-muted)] tnum whitespace-nowrap">{skill.year}y</span>
          </span>
          {skill.description && (
            <span class="block text-xs text-[var(--ink-muted)]">{skill.description}</span>
          )}
        </li>
      ))}
    </ul>
  </section>
</Layout>

<style>
  .about-section {
    padding: 2rem 1.75rem 2.4rem;
    margin-bottom: 1.5rem;
  }

  @media (min-width: 768px) {
    .about-section {
      padding: 2.25rem 2.25rem 2.6rem;
    }
  }

  .motivation-item {
    display: grid;
    grid-template-columns: 2.25rem minmax(0, 1fr);
    gap: 0 0.5rem;
  }

  .motivation-num {
    font-size: 1.15rem;
    font-style: italic;
    color: var(--ink-muted);
    line-height: 1.6;
  }

  .skill-row {
    display: flex;
    align-items: baseline;
  }

  .skill-item {
    break-inside: avoid;
    padding: 0.2rem 0;
  }
</style>
