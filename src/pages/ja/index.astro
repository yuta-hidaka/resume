---
import Layout from '../../layouts/Layout.astro';
import { getData } from '../../data/about.ja';

const data = getData('ja');
const current = data.experience?.[0];
---

<Layout>
  <section class="hero pt-8 md:pt-14 pb-12 md:pb-16">
    <div class="hero-text">
      <p class="section-label">Software Engineer — Tokyo</p>
      <h1 class="name-display font-display mt-4">{data.family_name} {data.given_name}</h1>
      <p class="font-display italic text-lg text-[var(--ink-muted)] mt-2" lang="en">Yuta Hidaka</p>
      <p class="text-[var(--ink-secondary)] mt-5">{data.profession}</p>
    </div>

    <figure class="hero-portrait">
      <img
        src="/me.jpeg"
        alt={`${data.family_name} ${data.given_name}`}
        width="384"
        height="480"
        loading="eager"
      />
    </figure>
  </section>

  <hr class="rule" />

  <section class="pt-12 md:pt-14">
    <p class="bio-text text-[var(--ink-secondary)] leading-loose">{data.bio}</p>

    <dl class="mt-10 grid grid-cols-[auto_1fr] gap-x-8 gap-y-2.5 text-sm max-w-xl">
      {current && (
        <>
          <dt class="text-[var(--ink-muted)]">現在</dt>
          <dd>{current.company} — {current.jobTitle}</dd>
        </>
      )}
      <dt class="text-[var(--ink-muted)]">拠点</dt>
      <dd>{data.address}</dd>
    </dl>

    {data.social && (
      <ul class="mt-9 flex flex-wrap gap-x-7 gap-y-2 text-sm">
        {data.social.map((social) => (
          <li>
            <a href={social.url} target="_blank" rel="noopener noreferrer" class="text-link">
              {social.name} ↗
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
</Layout>

<style>
  .hero {
    display: grid;
    gap: 2.5rem;
    align-items: center;
  }

  @media (min-width: 768px) {
    .hero {
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 3.5rem;
    }
  }

  .name-display {
    font-size: clamp(2.75rem, 9vw, 4.25rem);
    font-weight: 500;
    line-height: 1.15;
    letter-spacing: 0.06em;
  }

  .hero-portrait {
    width: 200px;
    justify-self: start;
  }

  @media (min-width: 768px) {
    .hero-portrait {
      width: 224px;
      justify-self: end;
    }
  }

  .hero-portrait img {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border-radius: 12px;
    border: 1px solid var(--line);
  }

  .bio-text {
    max-width: 42rem;
  }
</style>
