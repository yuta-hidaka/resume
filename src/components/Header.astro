---
import { getLangFromUrl, getRouteFromUrl, useTranslations, getLocalizedPath, type Lang } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const route = getRouteFromUrl(Astro.url);
const t = useTranslations(lang);

const links = [
  { label: t('nav.home'), path: '/' },
  { label: t('nav.career'), path: '/career' },
  { label: t('nav.about'), path: '/about' },
  { label: t('nav.downloads'), path: '/downloads' },
];

const otherLang: Lang = lang === 'ja' ? 'en' : 'ja';
const langSwitchPath = `/${otherLang}${route ? '/' + route : ''}`;
const langSwitchLabel = lang === 'ja' ? 'EN' : '日本語';
const siteName = lang === 'ja' ? '日髙 悠太' : 'Yuta Hidaka';
const menuLabel = lang === 'ja' ? 'メニュー' : 'Menu';

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="glass site-header-bar max-w-3xl mx-auto px-5 sm:px-7 py-3.5 flex flex-wrap items-baseline gap-x-7 gap-y-2">
    <a href={getLocalizedPath(lang, '/')} class="site-name font-display">{siteName}</a>

    <nav id="site-nav" class="site-nav order-4 w-full md:order-2 md:w-auto md:ml-2" aria-label="Main">
      <ul class="nav-list">
        {links.map((link) => {
          const href = getLocalizedPath(lang, link.path);
          const isActive = currentPath === href || currentPath === href + '/';
          return (
            <li>
              <a href={href} class:list={['nav-item', isActive && 'nav-item-active']} aria-current={isActive ? 'page' : undefined}>
                {link.label}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>

    <div class="order-2 ml-auto flex items-baseline gap-4 sm:gap-5 md:order-3">
      <a href={langSwitchPath} class="lang-switch" lang={otherLang} hreflang={otherLang}>{langSwitchLabel}</a>
      <button id="theme-toggle" class="icon-btn" aria-label={lang === 'ja' ? 'テーマ切り替え' : 'Toggle theme'}>
        <svg id="theme-icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="12" cy="12" r="4"/>
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
        </svg>
        <svg id="theme-icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="display: none;">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>
      <button
        id="menu-toggle"
        class="icon-btn menu-btn"
        aria-label={menuLabel}
        aria-expanded="false"
        aria-controls="site-nav"
      >
        <svg id="menu-icon-open" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <line x1="4" y1="7" x2="20" y2="7"/>
          <line x1="4" y1="12" x2="20" y2="12"/>
          <line x1="4" y1="17" x2="20" y2="17"/>
        </svg>
        <svg id="menu-icon-close" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="display: none;">
          <line x1="6" y1="6" x2="18" y2="18"/>
          <line x1="18" y1="6" x2="6" y2="18"/>
        </svg>
      </button>
    </div>
  </div>
</header>

<script is:inline>
  // Theme toggle
  (function() {
    const themeToggle = document.getElementById('theme-toggle');
    const html = document.documentElement;

    const updateIcons = (theme) => {
      const sunIcon = document.getElementById('theme-icon-sun');
      const moonIcon = document.getElementById('theme-icon-moon');
      if (sunIcon && moonIcon) {
        sunIcon.style.display = theme === 'dark' ? 'block' : 'none';
        moonIcon.style.display = theme === 'dark' ? 'none' : 'block';
      }
    };

    const setTheme = (theme) => {
      html.classList.toggle('light', theme === 'light');
      html.classList.toggle('dark', theme === 'dark');
      localStorage.setItem('theme', theme);
      updateIcons(theme);
      if (themeToggle) themeToggle.setAttribute('aria-pressed', String(theme === 'dark'));
    };

    const initialTheme = html.classList.contains('light') ? 'light' : 'dark';
    updateIcons(initialTheme);
    if (themeToggle) themeToggle.setAttribute('aria-pressed', String(initialTheme === 'dark'));

    if (themeToggle) {
      themeToggle.addEventListener('click', () => {
        const current = html.classList.contains('light') ? 'light' : 'dark';
        setTheme(current === 'dark' ? 'light' : 'dark');
      });
    }
  })();

  // Mobile menu toggle — the glass capsule stretches open
  (function() {
    const menuToggle = document.getElementById('menu-toggle');
    const nav = document.getElementById('site-nav');
    const openIcon = document.getElementById('menu-icon-open');
    const closeIcon = document.getElementById('menu-icon-close');
    if (!menuToggle || !nav || !openIcon || !closeIcon) return;

    const setOpen = (open) => {
      nav.classList.toggle('nav-open', open);
      menuToggle.setAttribute('aria-expanded', String(open));
      openIcon.style.display = open ? 'none' : 'block';
      closeIcon.style.display = open ? 'block' : 'none';
    };

    menuToggle.addEventListener('click', () => {
      setOpen(!nav.classList.contains('nav-open'));
    });

    nav.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => setOpen(false));
    });

    document.addEventListener('click', (e) => {
      if (!nav.classList.contains('nav-open')) return;
      if (!nav.contains(e.target) && !menuToggle.contains(e.target)) setOpen(false);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && nav.classList.contains('nav-open')) {
        setOpen(false);
        menuToggle.focus();
      }
    });
  })();
</script>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    padding: 14px 16px 0;
    pointer-events: none;
  }

  .site-header-bar {
    pointer-events: auto;
  }

  .site-name {
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--ink);
  }

  /* Mobile: hidden until the hamburger opens it; desktop: always inline */
  .site-nav {
    display: none;
  }

  .site-nav.nav-open {
    display: block;
  }

  .nav-list {
    display: flex;
    flex-direction: column;
    padding: 0.4rem 0 0.5rem;
  }

  .nav-list > li + li {
    border-top: 1px solid var(--line);
  }

  .nav-item {
    display: block;
    padding: 0.65rem 0.25rem;
    font-size: 0.95rem;
    color: var(--ink-muted);
    transition: color 0.15s ease;
    white-space: nowrap;
  }

  .nav-item:hover {
    color: var(--ink);
  }

  .nav-item-active {
    color: var(--ink);
    text-decoration: underline;
    text-decoration-thickness: 1.5px;
    text-underline-offset: 0.45em;
    text-decoration-color: var(--accent);
  }

  @media (prefers-reduced-motion: no-preference) {
    .site-nav.nav-open .nav-list {
      animation: navReveal 0.22s ease;
    }

    @keyframes navReveal {
      from {
        opacity: 0;
        transform: translateY(-4px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  }

  @media (min-width: 768px) {
    .site-nav {
      display: block;
    }

    .nav-list {
      flex-direction: row;
      align-items: baseline;
      gap: 0 1.5rem;
      padding: 0;
    }

    .nav-list > li + li {
      border-top: none;
    }

    .nav-item {
      display: inline-flex;
      padding: 0;
      font-size: 0.875rem;
    }
  }

  .lang-switch {
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--ink-muted);
    transition: color 0.15s ease;
  }

  .lang-switch:hover {
    color: var(--ink);
  }

  .icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    align-self: center;
    width: 30px;
    height: 30px;
    padding: 0;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--ink-muted);
    transition: color 0.15s ease;
  }

  .icon-btn:hover {
    color: var(--ink);
  }

  .icon-btn svg {
    width: 17px;
    height: 17px;
  }

  @media (min-width: 768px) {
    .menu-btn {
      display: none;
    }
  }
</style>
