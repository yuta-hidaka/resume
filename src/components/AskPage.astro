---
import { getLangFromUrl } from '../i18n/utils';
import { askConfig, samplePrompts } from '../lib/ask/profile';
import { getAskStrings } from '../lib/ask/strings';
import { MODELS } from '../lib/ask/config';

const lang = getLangFromUrl(Astro.url);
const s = getAskStrings(lang);
const cfg = askConfig(lang);
const chips = samplePrompts(lang);
const modelHref = 'https://huggingface.co/SakanaAI/TinySwallow-1.5B-Instruct';
---

<div id="askpage" data-lang={lang}>
  <script type="application/json" id="askpage-config" set:html={JSON.stringify(cfg)} is:inline />

  <section class="askp-hero">
    <p class="askp-eyebrow"><span class="askp-eyebrow-dot" aria-hidden="true"></span>{s.eyebrow}</p>
    <h1 class="askp-title font-display">{s.pageTitle}</h1>
    <p class="askp-lead">{s.pageLead}</p>

    <form class="askp-console" id="askp-form">
      <span class="askp-mark" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <path d="M2.5 10.5c4-4 7-3.2 9.5 1 2.5-4.2 5.5-5 9.5-1" />
          <path d="M12 11.5l-1.4 4.4M12 11.5l1.4 4.4" />
        </svg>
      </span>
      <textarea id="askp-input" class="askp-input" rows="1" placeholder={s.placeholder} autocomplete="off" aria-label={s.placeholder}></textarea>
      <button type="button" class="askp-stop" id="askp-stop" hidden>
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><rect x="7" y="7" width="10" height="10" rx="2" /></svg>
        <span>{s.stop}</span>
      </button>
      <button type="submit" class="askp-send" id="askp-send">
        <span>{s.send}</span>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h13M13 6l6 6-6 6" /></svg>
      </button>
    </form>

    <div class="askp-underbar">
      <span class="askp-device" id="askp-device">{s.device('webgpu')}</span>
      <ul class="askp-chips" id="askp-chips">
        {chips.map((c) => (
          <li><button type="button" class="askp-chip" data-prompt={c}>{c}</button></li>
        ))}
      </ul>
    </div>

    <div class="askp-load" id="askp-load" hidden>
      <div class="askp-load-bar"><span id="askp-load-fill"></span></div>
      <p class="askp-load-text" id="askp-load-text">{s.loadingBrowser}</p>
    </div>

    <div class="askp-confirm" id="askp-confirm" role="alertdialog" aria-live="assertive" hidden>
      <span class="askp-confirm-ico" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l9 16H3z"/><path d="M12 10v4M12 17.5v.01"/></svg>
      </span>
      <div class="askp-confirm-body">
        <p class="askp-confirm-title" id="askp-confirm-title"></p>
        <p class="askp-confirm-note">{s.confirmNote}</p>
        <div class="askp-confirm-actions">
          <button type="button" class="askp-confirm-cancel" id="askp-confirm-cancel">{s.confirmCancel}</button>
          <button type="button" class="askp-confirm-go" id="askp-confirm-go">{s.confirmGo}</button>
        </div>
      </div>
    </div>

    <div class="askp-engine" id="askp-engine">
      <p class="askp-mode-q">{s.modeQuestion}</p>
      <div class="askp-mode" role="radiogroup" aria-label={s.modeQuestion}>
        <button type="button" class="askp-mode-opt is-active" data-mode="retrieval" id="askp-mode-retrieval" role="radio" aria-checked="true">
          <span class="askp-mode-ico" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3h8l4 4v14H6z"/><path d="M14 3v4h4M9 13h6M9 17h6"/></svg>
          </span>
          <span class="askp-mode-t"><b>{s.modeRetrieval}</b><em>{s.modeRetrievalNote}</em></span>
        </button>
        <button type="button" class="askp-mode-opt" data-mode="ai" id="askp-mode-ai" role="radio" aria-checked="false">
          <span class="askp-mode-ico" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M2.5 11c4-4.2 7-3.4 9.5 1 2.5-4.4 5.5-5.2 9.5-1"/><path d="M12 12l-1.6 5M12 12l1.6 5"/></svg>
          </span>
          <span class="askp-mode-t"><b>{s.modeAi}</b><em>{s.modeAiNote}</em></span>
        </button>
      </div>

      <div class="askp-ai-controls" id="askp-ai-controls" hidden>
        <p class="askp-engine-lead">{s.engineLead}</p>
        <div class="askp-engine-row">
          <label class="askp-field">
            <span>{s.engineModelLabel}</span>
            <select id="askp-model" class="askp-select">
              {MODELS.map((m) => (
                <option
                  value={m.id}
                  data-webgpu={m.webgpuDtype}
                  data-wasm={m.wasmDtype}
                  data-size-q4f16={m.sizes.q4f16}
                  data-size-q8={m.sizes.q8}
                  data-size-q4={m.sizes.q4}
                  data-label={m.label}
                  data-note-ja={m.noteJa}
                  data-note-en={m.noteEn}
                >{m.label} · {m.params} · {m.by}</option>
              ))}
            </select>
          </label>
          <label class="askp-field">
            <span>{s.enginePrecisionLabel}</span>
            <select id="askp-precision" class="askp-select"></select>
          </label>
          <button type="button" class="askp-load-btn" id="askp-loadbtn"></button>
        </div>
        <p class="askp-engine-note" id="askp-engine-note"></p>
      </div>
    </div>
  </section>

  <div class="askp-thread" id="askp-thread" aria-live="polite"></div>

  <!-- How it works -->
  <section class="askp-how">
    <div class="askp-how-head">
      <h2 class="askp-how-title font-display">{s.howTitle}</h2>
      <p class="askp-how-lead">{s.howLead}</p>
    </div>
    <div class="askp-how-grid">
      <article class="askp-card">
        <span class="askp-card-ico" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M2.5 11c4-4.2 7-3.4 9.5 1 2.5-4.4 5.5-5.2 9.5-1" /><path d="M12 12l-1.6 5M12 12l1.6 5" />
          </svg>
        </span>
        <p class="askp-card-label">{s.howModelLabel}</p>
        <p class="askp-card-name">{s.howModelName}</p>
        <p class="askp-card-by"><a href={modelHref} target="_blank" rel="noopener noreferrer" class="text-link">{s.howModelBy} ↗</a></p>
        <p class="askp-card-desc">{s.howModelDesc}</p>
      </article>

      <article class="askp-card">
        <span class="askp-card-ico" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="4" width="18" height="16" rx="2.5" /><path d="M3 8.5h18" /><path d="M11 14.5l-2-2 2-2M14 12.5h1.5" />
          </svg>
        </span>
        <p class="askp-card-label">{s.howRuntimeLabel}</p>
        <p class="askp-card-name">{s.howRuntimeName}</p>
        <p class="askp-card-by">Hugging Face · ONNX</p>
        <p class="askp-card-desc">{s.howRuntimeDesc}</p>
      </article>

      <article class="askp-card">
        <span class="askp-card-ico" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 3l7 3v5c0 4.4-3 7.5-7 9-4-1.5-7-4.6-7-9V6z" /><path d="M9 12l2 2 4-4" />
          </svg>
        </span>
        <p class="askp-card-label">{s.howGroundLabel}</p>
        <p class="askp-card-name">{s.howGroundName}</p>
        <p class="askp-card-by">RAG + verify</p>
        <p class="askp-card-desc">{s.howGroundDesc}</p>
      </article>
    </div>
    <p class="askp-stacknote">{s.stackNote}</p>
  </section>
</div>

<script>
  import { getEngine } from '../lib/ask/engine';
  import { buildMessages, retrieve } from '../lib/ask/retrieve';
  import { guardedAnswer, safeFallback } from '../lib/ask/verify';
  import { getAskStrings } from '../lib/ask/strings';

  const rootEl = document.getElementById('askpage');
  if (rootEl) {
    const lang = (rootEl.getAttribute('data-lang') === 'en' ? 'en' : 'ja') as 'ja' | 'en';
    const t = getAskStrings(lang);
    const cfg = JSON.parse(document.getElementById('askpage-config')?.textContent || '{}');

    const form = document.getElementById('askp-form') as HTMLFormElement;
    const input = document.getElementById('askp-input') as HTMLTextAreaElement;
    const sendBtn = document.getElementById('askp-send')!;
    const stopBtn = document.getElementById('askp-stop')!;
    const thread = document.getElementById('askp-thread')!;
    const loadWrap = document.getElementById('askp-load')!;
    const loadFill = document.getElementById('askp-load-fill')!;
    const loadText = document.getElementById('askp-load-text')!;
    const deviceLine = document.getElementById('askp-device')!;

    const engine = getEngine();
    const history: { role: 'user' | 'assistant'; content: string }[] = [];
    let busy = false;
    deviceLine.textContent = t.device(engine.caps.device);
    if (!engine.caps.webgpu) deviceLine.classList.add('is-warn');

    // ——— Answer mode + model picker (always visible; default = résumé data) ———
    const device = engine.caps.device;
    let mode: 'retrieval' | 'ai' = 'retrieval';
    const modeBtns = [...document.querySelectorAll<HTMLButtonElement>('.askp-mode-opt')];
    const aiControls = document.getElementById('askp-ai-controls')!;
    const modelSel = document.getElementById('askp-model') as HTMLSelectElement;
    const precSel = document.getElementById('askp-precision') as HTMLSelectElement;
    const loadBtn = document.getElementById('askp-loadbtn') as HTMLButtonElement;
    const engineNote = document.getElementById('askp-engine-note')!;
    const DTYPES = device === 'webgpu' ? ['q4f16', 'q8'] : ['q8', 'q4'];
    const SIZE_KEY: Record<string, string> = { q4f16: 'sizeQ4f16', q8: 'sizeQ8', q4: 'sizeQ4' };

    const curOpt = () => modelSel.selectedOptions[0];
    const chosenModelId = () => (mode === 'ai' ? modelSel.value : null);
    const chosenDtype = () => precSel.value || DTYPES[0];
    const sizeOf = (opt: HTMLOptionElement, dt: string) => parseFloat(opt.dataset[SIZE_KEY[dt]] || '0') || 0;

    function updateLoadBtn() {
      const modelId = modelSel.value;
      const gb = sizeOf(curOpt(), chosenDtype());
      const loaded = engine.ready && engine.loadedModelId === modelId;
      loadBtn.classList.toggle('is-loaded', loaded);
      loadBtn.disabled = loaded;
      loadBtn.textContent = loaded ? `✓ ${t.engineLoaded(curOpt().dataset.label || '')}` : t.engineLoad(gb);
    }
    function refreshPrecision() {
      precSel.innerHTML = '';
      for (const dt of DTYPES) {
        const gb = sizeOf(curOpt(), dt);
        if (!gb) continue;
        const o = document.createElement('option');
        o.value = dt;
        o.textContent = `${dt} · ${t.engineSizePrefix}${gb}GB`;
        precSel.appendChild(o);
      }
      engineNote.textContent = (lang === 'ja' ? curOpt().dataset.noteJa : curOpt().dataset.noteEn) || '';
      updateLoadBtn();
    }
    function setMode(next: 'retrieval' | 'ai') {
      mode = next;
      modeBtns.forEach((b) => {
        const on = b.dataset.mode === next;
        b.classList.toggle('is-active', on);
        b.setAttribute('aria-checked', String(on));
      });
      aiControls.hidden = next !== 'ai';
      if (next === 'ai') refreshPrecision();
    }
    modeBtns.forEach((b) => b.addEventListener('click', () => setMode(b.dataset.mode as 'retrieval' | 'ai')));
    modelSel.addEventListener('change', refreshPrecision);
    precSel.addEventListener('change', updateLoadBtn);
    loadBtn.addEventListener('click', async () => {
      loadBtn.disabled = true;
      await ensureModel(modelSel.value, chosenDtype());
      updateLoadBtn();
    });

    const SVG = {
      orb: '<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="4" fill="currentColor"/><circle cx="12" cy="12" r="8.5" stroke="currentColor" stroke-width="1.2" opacity="0.5"/></svg>',
      check: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M8.5 12.2l2.4 2.4 4.6-4.8"/></svg>',
      shield: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3l7 3v5c0 4.4-3 7.5-7 9-4-1.5-7-4.6-7-9V6z"/><path d="M9 12l2 2 4-4"/></svg>',
      doc: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 3h8l4 4v14H6z"/><path d="M14 3v4h4M9 13h6M9 17h6"/></svg>',
    };

    const autosize = () => {
      input.style.height = 'auto';
      input.style.height = Math.min(input.scrollHeight, 200) + 'px';
    };
    input.addEventListener('input', autosize);
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        form.requestSubmit();
      }
    });
    document.querySelectorAll<HTMLButtonElement>('.askp-chip').forEach((chip) => {
      chip.addEventListener('click', () => {
        input.value = chip.dataset.prompt || '';
        autosize();
        form.requestSubmit();
      });
    });

    function el(tag: string, cls?: string, html?: string): HTMLElement {
      const n = document.createElement(tag);
      if (cls) n.className = cls;
      if (html != null) n.innerHTML = html;
      return n;
    }

    function addQA(question: string) {
      const block = el('article', 'askp-qa');
      const q = el('p', 'askp-q font-display');
      q.textContent = question;
      const a = el('div', 'askp-a is-streaming');
      const draft = el('div', 'askp-draft');
      draft.innerHTML = `<span class="askp-orb">${SVG.orb}</span><span class="askp-draft-label">${t.thinking}</span>`;
      a.appendChild(draft);
      block.appendChild(q);
      block.appendChild(a);
      thread.prepend(block);
      return { block, a };
    }

    function buildSources(query: string): HTMLElement | null {
      const hits = retrieve(query, cfg.chunks, 3);
      if (!hits.length) return null;
      const d = el('details', 'askp-sources');
      const sum = el('summary', 'askp-sources-sum', `${SVG.doc}<span>${t.sources}</span><span class="askp-sources-n">${hits.length}</span>`);
      const list = el('ul', 'askp-sources-list');
      hits.forEach((h: any) => {
        const li = el('li', 'askp-source');
        li.textContent = h.text;
        list.appendChild(li);
      });
      d.appendChild(sum);
      d.appendChild(list);
      return d;
    }

    function commit(a: HTMLElement, query: string, text: string, kind: 'verified' | 'corrected' | 'retrieval') {
      a.classList.remove('is-streaming');
      a.innerHTML = '';
      const body = el('div', 'askp-a-body');
      body.textContent = text;
      a.appendChild(body);

      const conf = {
        verified: { cls: 'is-verified', icon: SVG.check, title: t.verified, hint: t.verifiedHint },
        corrected: { cls: 'is-corrected', icon: SVG.shield, title: t.corrected, hint: t.correctedHint },
        retrieval: { cls: 'is-retrieval', icon: SVG.doc, title: t.retrievalBadge, hint: t.retrievalHint },
      }[kind];
      const badge = el(
        'div',
        `askp-badge ${conf.cls}`,
        `${conf.icon}<div class="askp-badge-txt"><b>${conf.title}</b><span>${conf.hint}</span></div>`,
      );
      a.appendChild(badge);

      const src = buildSources(query);
      if (src) a.appendChild(src);
    }

    function setBusy(on: boolean) {
      busy = on;
      sendBtn.hidden = on;
      stopBtn.hidden = !on;
    }

    // Show a size warning and wait for the visitor to confirm before any download.
    const confirmBox = document.getElementById('askp-confirm')!;
    const confirmTitle = document.getElementById('askp-confirm-title')!;
    const confirmGo = document.getElementById('askp-confirm-go')!;
    const confirmCancel = document.getElementById('askp-confirm-cancel')!;
    function confirmDownload(label: string, mb: number): Promise<boolean> {
      confirmTitle.textContent = t.confirmTitle(label, mb);
      confirmBox.hidden = false;
      confirmBox.scrollIntoView({ block: 'nearest' });
      return new Promise((resolve) => {
        const done = (ok: boolean) => {
          confirmBox.hidden = true;
          confirmGo.removeEventListener('click', onGo);
          confirmCancel.removeEventListener('click', onCancel);
          resolve(ok);
        };
        const onGo = () => done(true);
        const onCancel = () => done(false);
        confirmGo.addEventListener('click', onGo);
        confirmCancel.addEventListener('click', onCancel);
      });
    }

    async function ensureModel(modelId: string, dtype: string): Promise<boolean> {
      if (engine.ready && engine.loadedModelId === modelId) return true;
      // Warn about the download size and require an explicit OK first.
      const mb = Math.round(sizeOf(curOpt(), dtype) * 1000);
      if (!(await confirmDownload(curOpt().dataset.label || '', mb))) return false;
      loadWrap.hidden = false;
      loadText.textContent = t.loadingBrowser;
      try {
        await engine.load({
          modelId,
          dtype: dtype as any,
          onProgress: (p) => {
            if (typeof p.progress === 'number' && p.status === 'progress') {
              loadFill.style.width = Math.round(p.progress) + '%';
              const mb = p.total ? ` · ${(p.loaded! / 1e6).toFixed(0)}/${(p.total / 1e6).toFixed(0)} MB` : '';
              loadText.textContent = `${t.loading} ${Math.round(p.progress)}%${mb}`;
            }
          },
        });
        loadWrap.hidden = true;
        return true;
      } catch {
        loadWrap.hidden = true;
        return false;
      }
    }

    async function submit(text: string) {
      if (busy || !text.trim()) return;
      const q = text.trim();
      input.value = '';
      autosize();
      const { a } = addQA(q);
      setBusy(true);

      // Default: retrieval — instant answer from the résumé, no download.
      const modelId = chosenModelId();
      if (!modelId) {
        commit(a, q, safeFallback(cfg, q), 'retrieval');
        setBusy(false);
        return;
      }

      // Model mode: load (if needed) then generate, gated by the verifier.
      // If the visitor cancels the download (or it fails), fall back to retrieval.
      const ok = await ensureModel(modelId, chosenDtype());
      updateLoadBtn();
      if (!ok) {
        commit(a, q, safeFallback(cfg, q), 'retrieval');
        setBusy(false);
        return;
      }

      let acc = '';
      let draftBody: HTMLElement | null = null;
      engine.ask(buildMessages(cfg, q, history), {
        onStart: () => {
          a.innerHTML = '';
          draftBody = el('div', 'askp-a-body is-draft');
          const tag = el('span', 'askp-draft-tag', t.generating);
          a.appendChild(tag);
          a.appendChild(draftBody);
        },
        onToken: (tok) => {
          acc += tok;
          if (draftBody) draftBody.textContent = acc;
        },
        onDone: (full) => {
          // The single gate: verified answer, or verified facts. Never a lie.
          const { text, verified } = guardedAnswer(cfg, q, full || acc);
          commit(a, q, text, verified ? 'verified' : 'corrected');
          if (verified) history.push({ role: 'user', content: q }, { role: 'assistant', content: text });
          setBusy(false);
        },
        onError: () => {
          commit(a, q, safeFallback(cfg, q), 'corrected');
          setBusy(false);
        },
      });
    }

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      submit(input.value);
    });
    stopBtn.addEventListener('click', () => engine.stop());
  }
</script>

<!-- Global (not scoped): the thread/answer/badge/source nodes are created at
     runtime via createElement, which Astro's scoped styles don't reach. All
     selectors are unique .askp-* names, so there is no leakage. -->
<style is:global>
  #askpage { --a: var(--accent); }

  /* ——— Hero ——— */
  .askp-hero { position: relative; padding-top: 1.5rem; }
  @media (min-width: 768px) { .askp-hero { padding-top: 2.5rem; } }

  .askp-eyebrow {
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-size: 0.7rem; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--a);
  }
  .askp-eyebrow-dot {
    width: 6px; height: 6px; border-radius: 50%; background: var(--a);
    box-shadow: 0 0 0 0 color-mix(in srgb, var(--a) 60%, transparent);
    animation: askpPulse 2.4s ease-out infinite;
  }
  @keyframes askpPulse {
    0% { box-shadow: 0 0 0 0 color-mix(in srgb, var(--a) 55%, transparent); }
    70% { box-shadow: 0 0 0 7px transparent; }
    100% { box-shadow: 0 0 0 0 transparent; }
  }

  .askp-title {
    font-size: clamp(2.4rem, 6.5vw, 3.4rem); font-weight: 500; line-height: 1.12;
    letter-spacing: 0.005em; color: var(--ink); margin-top: 1rem;
  }
  .askp-lead {
    max-width: 40rem; margin-top: 1.1rem; color: var(--ink-secondary);
    font-size: 1.02rem; line-height: 1.8;
  }

  /* ——— Console (input) ——— */
  .askp-console {
    position: relative; display: flex; align-items: flex-end; gap: 0.6rem;
    margin-top: 2rem; padding: 0.85rem 0.85rem 0.85rem 0.9rem;
    background: var(--surface); border: 1px solid var(--line-strong); border-radius: 16px;
    box-shadow: 0 1px 2px rgba(0,0,0,0.04), 0 18px 40px -28px rgba(0,0,0,0.4);
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .askp-console:focus-within {
    border-color: var(--a);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--a) 12%, transparent), 0 18px 40px -26px color-mix(in srgb, var(--a) 55%, transparent);
  }
  .askp-mark {
    flex: none; display: flex; align-items: center; justify-content: center;
    width: 34px; height: 34px; margin-bottom: 2px; color: var(--a);
  }
  .askp-mark svg { width: 22px; height: 22px; }
  .askp-input {
    flex: 1; min-width: 0; resize: none; border: none; background: none; color: var(--ink);
