---
import { getLangFromUrl } from '../i18n/utils';
import { askConfig, samplePrompts } from '../lib/ask/profile';
import { getAskStrings } from '../lib/ask/strings';
import { MODELS } from '../lib/ask/config';

const lang = getLangFromUrl(Astro.url);
const s = getAskStrings(lang);
const cfg = askConfig(lang);
const chips = samplePrompts(lang);
const modelHref = 'https://huggingface.co/SakanaAI/TinySwallow-1.5B-Instruct';
---

<div id="askpage" data-lang={lang}>
  <script type="application/json" id="askpage-config" set:html={JSON.stringify(cfg)} is:inline />

  <section class="askp-hero">
    <p class="askp-eyebrow"><span class="askp-eyebrow-dot" aria-hidden="true"></span>{s.eyebrow}</p>
    <h1 class="askp-title font-display">{s.pageTitle}</h1>
    <p class="askp-lead">{s.pageLead}</p>

    <form class="askp-console" id="askp-form">
      <div class="askp-console-top">
        <span class="askp-mark" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M2.5 10.5c4-4 7-3.2 9.5 1 2.5-4.2 5.5-5 9.5-1" />
            <path d="M12 11.5l-1.4 4.4M12 11.5l1.4 4.4" />
          </svg>
        </span>
        <textarea id="askp-input" class="askp-input" rows="1" placeholder={s.placeholder} autocomplete="off" aria-label={s.placeholder}></textarea>
        <div class="askp-actions">
          <button type="button" class="askp-stop" id="askp-stop" aria-label={s.stop} title={s.stop} hidden>
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><rect x="7" y="7" width="10" height="10" rx="2" /></svg>
          </button>
          <button type="submit" class="askp-send" id="askp-send" aria-label={s.send} title={s.send}>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h13M13 6l6 6-6 6" /></svg>
          </button>
        </div>
      </div>
      <div class="askp-console-foot">
        <div class="askp-tools">
          <div class="askp-tool" title={s.engineModelLabel}>
            <span class="askp-tool-ico" id="askp-model-ico" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M2.5 11c4-4.2 7-3.4 9.5 1 2.5-4.4 5.5-5.2 9.5-1"/><path d="M12 12l-1.6 5M12 12l1.6 5"/></svg>
            </span>
            <select id="askp-model" class="askp-tool-select" aria-label={s.engineModelLabel}>
              {MODELS.map((m) => (
                <option
                  value={m.id}
                  data-webgpu={m.webgpuDtype}
                  data-wasm={m.wasmDtype}
                  data-size-q4f16={m.sizes.q4f16}
                  data-size-q8={m.sizes.q8}
                  data-size-q4={m.sizes.q4}
                  data-size-q4f32={m.sizes.q4f32}
                  data-label={m.label}
                  data-note-ja={m.noteJa}
                  data-note-en={m.noteEn}
                  data-webgpu-only={m.webgpuOnly ? '1' : undefined}
                >{m.label} · {s.engineSizePrefix}{m.sizes[m.webgpuDtype]}GB</option>
              ))}
              <option value="retrieval">{s.modeRetrieval}</option>
            </select>
            <svg class="askp-tool-chev" viewBox="0 0 10 6" aria-hidden="true"><path d="M1 1l4 4 4-4" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
          </div>
        </div>
      </div>
    </form>
    <p class="askp-model-hint" id="askp-model-hint"></p>

    <div class="askp-underbar">
      <span class="askp-device" id="askp-device">{s.device('webgpu')}</span>
      <ul class="askp-chips" id="askp-chips">
        {chips.map((c) => (
          <li><button type="button" class="askp-chip" data-prompt={c}>{c}</button></li>
        ))}
      </ul>
    </div>

    <div class="askp-load" id="askp-load" hidden>
      <div class="askp-load-bar"><span id="askp-load-fill"></span></div>
      <p class="askp-load-text" id="askp-load-text">{s.loadingBrowser}</p>
    </div>

    <div class="askp-confirm" id="askp-confirm" role="alertdialog" aria-live="assertive" hidden>
      <span class="askp-confirm-ico" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l9 16H3z"/><path d="M12 10v4M12 17.5v.01"/></svg>
      </span>
      <div class="askp-confirm-body">
        <p class="askp-confirm-title" id="askp-confirm-title"></p>
        <p class="askp-confirm-note">{s.confirmNote}</p>
        <div class="askp-confirm-actions">
          <button type="button" class="askp-confirm-cancel" id="askp-confirm-cancel">{s.confirmCancel}</button>
          <button type="button" class="askp-confirm-go" id="askp-confirm-go">{s.confirmGo}</button>
        </div>
      </div>
    </div>

  </section>

  <div class="askp-thread" id="askp-thread" aria-live="polite"></div>

  <!-- How it works -->
  <section class="askp-how">
    <div class="askp-how-head">
      <h2 class="askp-how-title font-display">{s.howTitle}</h2>
      <p class="askp-how-lead">{s.howLead}</p>
    </div>
    <div class="askp-how-grid">
      <article class="askp-card">
        <span class="askp-card-ico" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M2.5 11c4-4.2 7-3.4 9.5 1 2.5-4.4 5.5-5.2 9.5-1" /><path d="M12 12l-1.6 5M12 12l1.6 5" />
          </svg>
        </span>
        <p class="askp-card-label">{s.howModelLabel}</p>
        <p class="askp-card-name">{s.howModelName}</p>
        <p class="askp-card-by"><a href={modelHref} target="_blank" rel="noopener noreferrer" class="text-link">{s.howModelBy} ↗</a></p>
        <p class="askp-card-desc">{s.howModelDesc}</p>
      </article>

      <article class="askp-card">
        <span class="askp-card-ico" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="4" width="18" height="16" rx="2.5" /><path d="M3 8.5h18" /><path d="M11 14.5l-2-2 2-2M14 12.5h1.5" />
          </svg>
        </span>
        <p class="askp-card-label">{s.howRuntimeLabel}</p>
        <p class="askp-card-name">{s.howRuntimeName}</p>
        <p class="askp-card-by">Hugging Face · ONNX / MLC</p>
        <p class="askp-card-desc">{s.howRuntimeDesc}</p>
      </article>

      <article class="askp-card">
        <span class="askp-card-ico" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 3l7 3v5c0 4.4-3 7.5-7 9-4-1.5-7-4.6-7-9V6z" /><path d="M9 12l2 2 4-4" />
          </svg>
        </span>
        <p class="askp-card-label">{s.howGroundLabel}</p>
        <p class="askp-card-name">{s.howGroundName}</p>
        <p class="askp-card-by">RAG + verify</p>
        <p class="askp-card-desc">{s.howGroundDesc}</p>
      </article>
    </div>
    <p class="askp-stacknote">{s.stackNote}</p>
  </section>
</div>

<script>
  import { getEngine, probeWebGPU } from '../lib/ask/engine';
  import { buildMessages, retrieve } from '../lib/ask/retrieve';
  import { guardedAnswer, safeFallback, fallbackFacts } from '../lib/ask/verify';
  import { getAskStrings } from '../lib/ask/strings';
  import { downloadStatus, stripThinking } from '../lib/ask/format';

  const rootEl = document.getElementById('askpage');
  if (rootEl) {
    const lang = (rootEl.getAttribute('data-lang') === 'en' ? 'en' : 'ja') as 'ja' | 'en';
    const t = getAskStrings(lang);
    const cfg = JSON.parse(document.getElementById('askpage-config')?.textContent || '{}');

    const form = document.getElementById('askp-form') as HTMLFormElement;
    const input = document.getElementById('askp-input') as HTMLTextAreaElement;
    const sendBtn = document.getElementById('askp-send')!;
    const stopBtn = document.getElementById('askp-stop')!;
    const thread = document.getElementById('askp-thread')!;
    const loadWrap = document.getElementById('askp-load')!;
    const loadFill = document.getElementById('askp-load-fill')!;
    const loadText = document.getElementById('askp-load-text')!;
    const deviceLine = document.getElementById('askp-device')!;

    const engine = getEngine();
    const history: { role: 'user' | 'assistant'; content: string }[] = [];
    let busy = false;

    // ——— In-composer model picker (default = a small in-browser LLM) ———
    // Model files are cached by the browser after the first download. We ask for
    // persistent storage so the browser won't evict the (large) weights, and we
    // remember — with a TTL — that a model was fetched, so a returning visitor
    // isn't warned about the size or made to re-download within that window.
    if ((navigator as any).storage?.persist) (navigator as any).storage.persist().catch(() => {});

    let device = engine.caps.device;
    const modelSel = document.getElementById('askp-model') as HTMLSelectElement;
    const modelHint = document.getElementById('askp-model-hint')!;
    const modelIco = document.getElementById('askp-model-ico')!;
    const SIZE_KEY: Record<string, string> = { q4f16: 'sizeQ4f16', q8: 'sizeQ8', q4: 'sizeQ4', q4f32: 'sizeQ4f32' };
    const ICO_DOC = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3h8l4 4v14H6z"/><path d="M14 3v4h4M9 13h6M9 17h6"/></svg>';
    const ICO_AI = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M2.5 11c4-4.2 7-3.4 9.5 1 2.5-4.4 5.5-5.2 9.5-1"/><path d="M12 12l-1.6 5M12 12l1.6 5"/></svg>';

    const CACHE_TTL_MS = 30 * 24 * 60 * 60 * 1000; // trust the browser cache for 30 days
    const CACHE_LS_KEY = 'askp:model-cache:v1';
    const readCache = (): Record<string, number> => {
      try { return JSON.parse(localStorage.getItem(CACHE_LS_KEY) || '{}'); } catch { return {}; }
    };
    const isCachedFresh = (key: string) => {
      const ts = readCache()[key];
      return typeof ts === 'number' && Date.now() - ts < CACHE_TTL_MS;
    };
    const markCached = (key: string) => {
      try { const m = readCache(); m[key] = Date.now(); localStorage.setItem(CACHE_LS_KEY, JSON.stringify(m)); } catch {}
    };

    // Whether the model weights are ACTUALLY still in the browser's Cache Storage.
    // localStorage only remembers that we downloaded once; the weights live in a
    // separate bucket the browser can evict on its own. We probe the real cache
    // before skipping the size confirm, so an evicted cache never triggers a
    // silent, unconsented re-download (nor a false "loading from cache").
    const isModelInCacheStorage = async (modelId: string): Promise<boolean> => {
      try {
        if (typeof caches === 'undefined') return false;
        for (const name of await caches.keys()) {
          const c = await caches.open(name);
          const reqs = await c.keys();
          if (reqs.some((r) => r.url.includes(modelId))) return true;
        }
        return false;
      } catch { return false; }
    };

    const isAi = () => modelSel.value !== 'retrieval';
    const curOpt = () => modelSel.selectedOptions[0];
    const chosenModelId = () => (isAi() ? modelSel.value : null);
    // Best precision for this backend (WebGPU can do fp16; WASM cannot).
    const chosenDtype = () => (device === 'webgpu' ? curOpt().dataset.webgpu : curOpt().dataset.wasm) || 'q8';
    const sizeOf = (opt: HTMLOptionElement, dt: string) => parseFloat(opt.dataset[SIZE_KEY[dt]] || '0') || 0;
    const cacheKey = () => `${modelSel.value}|${chosenDtype()}`;

    async function updateHint() {
      if (!isAi()) {
        modelHint.textContent = '';
        return;
      }
      const note = (lang === 'ja' ? curOpt().dataset.noteJa : curOpt().dataset.noteEn) || '';
      const sep = lang === 'ja' ? '　' : ' · ';
      const mb = Math.round(sizeOf(curOpt(), chosenDtype()) * 1000);
      const dl = lang === 'ja'
        ? `初回のみ 約${mb.toLocaleString()} MB ダウンロード`
        : `~${mb.toLocaleString()} MB on first use`;
      const cachedLabel = `${note}${sep}✓ ${t.cached}`;
      const dlLabel = `${note}${sep}${dl}`;
      const loaded = engine.ready && engine.loadedModelId === modelSel.value;
      // Optimistic first paint from the TTL marker, then correct against the real cache.
      modelHint.textContent = loaded || isCachedFresh(cacheKey()) ? cachedLabel : dlLabel;
      if (!loaded && isCachedFresh(cacheKey())) {
        const forId = modelSel.value;
        const present = await isModelInCacheStorage(forId);
        if (modelSel.value === forId) modelHint.textContent = present ? cachedLabel : dlLabel;
      }
    }
    function refreshModel() {
      modelIco.innerHTML = isAi() ? ICO_AI : ICO_DOC;
      updateHint();
    }
    // Warm-load an already-cached model in the background on intent (model pick or
    // input focus) so the first answer generates immediately — the weight read +
    // WebGPU warm-up happens while the visitor is still typing, not after they ask.
    // Cached-only: never triggers a download without the size confirm.
    const warmTried = new Set<string>();
    async function maybeWarmLoad() {
      if (!isAi()) return;
      const modelId = modelSel.value;
      const key = cacheKey();
      if (warmTried.has(key)) return;
      if (engine.ready && engine.loadedModelId === modelId) return;
      if (!isCachedFresh(key) || !(await isModelInCacheStorage(modelId))) return;
      warmTried.add(key);
      engine.load({ modelId, dtype: chosenDtype() as any }).catch(() => warmTried.delete(key));
    }
    modelSel.addEventListener('change', () => { refreshModel(); maybeWarmLoad(); });
    input.addEventListener('focus', () => { maybeWarmLoad(); });
    refreshModel();

    // WebLLM models (compiled WebGPU kernels, no WASM fallback) additionally
    // need a Chromium DESKTOP browser: WebLLM doesn't support Safari/Firefox,
    // and phones lack the memory for a 1.5B model — a real iPhone hard-crashed
    // (repeated WebContent kills) on it even though iOS 26 reports WebGPU.
    // navigator.userAgentData exists only on Chromium; .mobile filters phones.
    // ?backend=webgpu remains the escape hatch for testing.
    const forcedWebgpu = new URLSearchParams(location.search).get('backend') === 'webgpu';
    const uaData = (navigator as any).userAgentData;
    const webllmOk = forcedWebgpu || (!!uaData && uaData.mobile === false);

    // Device line + model availability.
    function applyDeviceUi() {
      deviceLine.textContent = t.device(device);
      deviceLine.classList.toggle('is-warn', device !== 'webgpu');
      for (const o of Array.from(modelSel.options)) {
        if (o.dataset.webgpuOnly) o.disabled = device !== 'webgpu' || !webllmOk;
      }
      // If the (default) selection got disabled, fall back to the first model
      // that can actually run here.
      if (modelSel.selectedOptions[0]?.disabled) {
        const firstEnabled = Array.from(modelSel.options).find((o) => !o.disabled);
        if (firstEnabled) modelSel.value = firstEnabled.value;
        refreshModel();
      }
      updateHint();
    }
    applyDeviceUi();

    // `'gpu' in navigator` can be a false positive (the object exists but no
    // adapter is available, and every WebGPU model load would fail). Verify
    // asynchronously and downgrade to WASM if the adapter is not real.
    // IMPORTANT: only probe once the tab is visible — Chromium can refuse
    // adapters to hidden tabs (e.g. opened via cmd-click in the background),
    // and probing there would wrongly lock a WebGPU machine to WASM. Nothing
    // can be interacted with while hidden, so waiting loses nothing.
    // ?backend=webgpu still forces WebGPU.
    if (device === 'webgpu' && !forcedWebgpu) {
      const probeWhenVisible = async (): Promise<boolean> => {
        if (document.visibilityState === 'hidden') {
          await new Promise<void>((resolve) => {
            const onVisible = () => {
              if (document.visibilityState !== 'hidden') {
                document.removeEventListener('visibilitychange', onVisible);
                resolve();
              }
            };
            document.addEventListener('visibilitychange', onVisible);
          });
        }
        return probeWebGPU();
      };
      probeWhenVisible().then((ok) => {
        if (!ok) {
          device = 'wasm';
          engine.setDevice('wasm');
          applyDeviceUi();
        }
      });
    }

    const SVG = {
      orb: '<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="4" fill="currentColor"/><circle cx="12" cy="12" r="8.5" stroke="currentColor" stroke-width="1.2" opacity="0.5"/></svg>',
      check: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M8.5 12.2l2.4 2.4 4.6-4.8"/></svg>',
      shield: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3l7 3v5c0 4.4-3 7.5-7 9-4-1.5-7-4.6-7-9V6z"/><path d="M9 12l2 2 4-4"/></svg>',
      doc: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 3h8l4 4v14H6z"/><path d="M14 3v4h4M9 13h6M9 17h6"/></svg>',
    };

    const autosize = () => {
      input.style.height = 'auto';
      input.style.height = Math.min(input.scrollHeight, 200) + 'px';
    };
    input.addEventListener('input', autosize);
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        form.requestSubmit();
      }
    });
    document.querySelectorAll<HTMLButtonElement>('.askp-chip').forEach((chip) => {
      chip.addEventListener('click', () => {
        input.value = chip.dataset.prompt || '';
        autosize();
        form.requestSubmit();
      });
    });

    function el(tag: string, cls?: string, html?: string): HTMLElement {
      const n = document.createElement(tag);
      if (cls) n.className = cls;
      if (html != null) n.innerHTML = html;
      return n;
    }

    function addQA(question: string) {
      const block = el('article', 'askp-qa');
      const q = el('p', 'askp-q font-display');
      q.textContent = question;
      const a = el('div', 'askp-a is-streaming');
      const draft = el('div', 'askp-draft');
      draft.innerHTML = `<span class="askp-orb">${SVG.orb}</span><span class="askp-draft-label">${t.thinking}</span>`;
      a.appendChild(draft);
      block.appendChild(q);
      block.appendChild(a);
      thread.prepend(block);
      return { block, a };
    }

    function buildSources(query: string): HTMLElement | null {
      const hits = retrieve(query, cfg.chunks, 3);
      if (!hits.length) return null;
      const d = el('details', 'askp-sources');
      const sum = el('summary', 'askp-sources-sum', `${SVG.doc}<span>${t.sources}</span><span class="askp-sources-n">${hits.length}</span>`);
      const list = el('ul', 'askp-sources-list');
      hits.forEach((h: any) => {
        const li = el('li', 'askp-source');
        li.textContent = h.text;
        list.appendChild(li);
      });
      d.appendChild(sum);
      d.appendChild(list);
      return d;
    }

    function appendBadgeAndSources(a: HTMLElement, query: string, kind: 'verified' | 'corrected' | 'retrieval' | 'timeout') {
      const conf = {
        verified: { cls: 'is-verified', icon: SVG.check, title: t.verified, hint: t.verifiedHint },
        corrected: { cls: 'is-corrected', icon: SVG.shield, title: t.corrected, hint: t.correctedHint },
        retrieval: { cls: 'is-retrieval', icon: SVG.doc, title: t.retrievalBadge, hint: t.retrievalHint },
        timeout: { cls: 'is-corrected', icon: SVG.shield, title: t.timeoutTitle, hint: t.timeoutHint },
      }[kind];
      const badge = el(
        'div',
        `askp-badge ${conf.cls}`,
        `${conf.icon}<div class="askp-badge-txt"><b>${conf.title}</b><span>${conf.hint}</span></div>`,
      );
      a.appendChild(badge);

      const src = buildSources(query);
      if (src) a.appendChild(src);
    }

    // Verified LLM prose — shown as a natural paragraph.
    function commit(a: HTMLElement, query: string, text: string, kind: 'verified' | 'corrected' | 'retrieval') {
      a.classList.remove('is-streaming');
      a.innerHTML = '';
      const body = el('div', 'askp-a-body');
      body.textContent = text;
      a.appendChild(body);
      appendBadgeAndSources(a, query, kind);
    }

    // Résumé facts (retrieval / corrected) — a short lead + a clean list, so it
    // reads as an answer instead of a run-on wall of gray text.
    function commitFacts(a: HTMLElement, query: string, facts: string[], kind: 'corrected' | 'retrieval' | 'timeout') {
      a.classList.remove('is-streaming');
      a.innerHTML = '';
      const lead = el('p', 'askp-a-lead');
      lead.textContent = t.factsLead;
      a.appendChild(lead);
      const list = (facts.length ? facts : [safeFallback(cfg, query)]).filter(Boolean);
      const ul = el('ul', 'askp-a-facts');
      list.forEach((f) => {
        const li = el('li');
        li.textContent = f;
        ul.appendChild(li);
      });
      a.appendChild(ul);
      appendBadgeAndSources(a, query, kind);
    }

    function setBusy(on: boolean) {
      busy = on;
      sendBtn.hidden = on;
      stopBtn.hidden = !on;
    }

    // Show a size warning and wait for the visitor to confirm before any download.
    const confirmBox = document.getElementById('askp-confirm')!;
    const confirmTitle = document.getElementById('askp-confirm-title')!;
    const confirmGo = document.getElementById('askp-confirm-go')!;
    const confirmCancel = document.getElementById('askp-confirm-cancel')!;
    function confirmDownload(label: string, mb: number): Promise<boolean> {
      confirmTitle.textContent = t.confirmTitle(label, mb);
      confirmBox.hidden = false;
      confirmBox.scrollIntoView({ block: 'nearest' });
      return new Promise((resolve) => {
        const done = (ok: boolean) => {
          confirmBox.hidden = true;
          confirmGo.removeEventListener('click', onGo);
          confirmCancel.removeEventListener('click', onCancel);
          resolve(ok);
        };
        const onGo = () => done(true);
        const onCancel = () => done(false);
        confirmGo.addEventListener('click', onGo);
        confirmCancel.addEventListener('click', onCancel);
      });
    }

    async function ensureModel(modelId: string, dtype: string): Promise<boolean> {
      if (engine.ready && engine.loadedModelId === modelId) return true;
      const key = `${modelId}|${dtype}`;
      // Trust the "already downloaded" marker only if the weights are still in
      // the cache — otherwise fall through and warn about the size as usual.
      const cached = isCachedFresh(key) && (await isModelInCacheStorage(modelId));
      // First time (or the cache window expired / weights evicted): warn first.
      if (!cached) {
        const mb = Math.round(sizeOf(curOpt(), dtype) * 1000);
        if (!(await confirmDownload(curOpt().dataset.label || '', mb))) return false;
      }
      loadWrap.hidden = false;
      loadText.textContent = cached ? t.loadingCache : t.loadingBrowser;
      // Track transfer rate for a live MB/s readout (EMA-smoothed; reset the
      // baseline when transformers.js moves to the next file — loaded resets).
      let prevLoaded = 0, prevMs = Date.now(), rateEma = 0;
      try {
        await engine.load({
          modelId,
          dtype: dtype as any,
          onProgress: (p) => {
            if (typeof p.progress === 'number' && p.status === 'progress') {
              loadFill.style.width = Math.round(p.progress) + '%';
              const now = Date.now();
              const loaded = p.loaded ?? 0;
              const dBytes = loaded - prevLoaded;
              const dt = (now - prevMs) / 1000;
              if (dBytes < 0) {
                prevLoaded = loaded; prevMs = now; // new file
              } else if (dt >= 0.25 && dBytes > 0) {
                const inst = dBytes / dt;
                rateEma = rateEma ? rateEma * 0.6 + inst * 0.4 : inst;
                prevLoaded = loaded; prevMs = now;
              }
              loadText.textContent = downloadStatus(t.loading, p.progress, loaded, p.total, rateEma);
            }
          },
        });
        markCached(key);
        loadWrap.hidden = true;
        return true;
      } catch {
        loadWrap.hidden = true;
        return false;
      }
    }

    async function submit(text: string) {
      if (busy || !text.trim()) return;
      const q = text.trim();
      input.value = '';
      autosize();
      const { a } = addQA(q);
      setBusy(true);

      // "No model" mode: instant answer from the résumé, no download.
      const modelId = chosenModelId();
      if (!modelId) {
        commitFacts(a, q, fallbackFacts(cfg, q), 'retrieval');
        setBusy(false);
        return;
      }

      // Model mode: load (if needed) then generate, gated by the verifier.
      // If the visitor cancels the download (or it fails), fall back to facts.
      const ok = await ensureModel(modelId, chosenDtype());
      updateHint();
      if (!ok) {
        commitFacts(a, q, fallbackFacts(cfg, q), 'retrieval');
        setBusy(false);
        return;
      }

      // Stream the model's draft live (clearly a DRAFT — the final answer is the
      // verified result rendered on 'done'). The verifier still decides what stands:
      // a verified answer, or a fall back to real résumé facts. A lie is never the
      // final answer — only ever a draft that then gets replaced. A stall watchdog
      // prevents an endless hang (and resets the worker so it doesn't poison the next
      // question).
      // NOTE: a single attempt. A sampling retry roughly doubled the wait for little
      // gain (a weak model that fails the verifier usually fails the retry too), so
      // speed wins — one generation, then verify-or-fall-back.
      const FIRST_TOKEN_MS = 60000; // WebGPU warm-up / shader compile can be slow
      const STALL_MS = 20000;       // …but a long gap mid-stream means it stalled
      const MAX_ATTEMPTS = 1;
      const orbHtml = (label: string) =>
        `<div class="askp-draft"><span class="askp-orb">${SVG.orb}</span><span class="askp-draft-label">${label}</span></div>`;

      const runAttempt = (n: number) => {
        let acc = '';
        let draftBody: HTMLElement | null = null;
        let settled = false;
        let gotToken = false;
        let lastTick = Date.now();
        let watchdog = 0 as unknown as ReturnType<typeof setInterval>;
        const settle = () => { settled = true; clearInterval(watchdog); };
        const reveal = (render: () => void) => {
          if (settled) return;
          settle();
          render();
          setBusy(false);
        };
        // kind='corrected' → a completed-but-bad attempt (retry-eligible);
        // kind='timeout'   → a hang (no retry: reset the worker, show facts).
        const failOut = (kind: 'corrected' | 'timeout') => {
          if (settled) return;
          settle();
          if (kind === 'timeout') engine.reset();
          if (kind === 'corrected' && n < MAX_ATTEMPTS) {
            a.innerHTML = orbHtml(t.retrying); // back to a spinner while it re-drafts
            runAttempt(n + 1); // second pass samples for a different result
            return;
          }
          commitFacts(a, q, fallbackFacts(cfg, q), kind);
          setBusy(false);
        };
        watchdog = setInterval(() => {
          if (settled) return;
          const limit = gotToken ? STALL_MS : FIRST_TOKEN_MS;
          if (Date.now() - lastTick > limit) {
            engine.stop(); // interrupt the hung / too-slow generation
            failOut('timeout');
          }
        }, 2500);

        engine.ask(buildMessages(cfg, q, history), {
          sample: n >= 2, // attempt 1 greedy (fastest, most factual); retry samples
          onStart: () => { lastTick = Date.now(); },
          onToken: (tok) => {
            lastTick = Date.now();
            acc += tok;
            if (!gotToken) {
              // First token — swap the "考えています…" orb for the live draft.
              gotToken = true;
              a.innerHTML = '';
              const tag = el('span', 'askp-draft-tag', t.generating);
              draftBody = el('div', 'askp-a-body is-draft');
              a.appendChild(tag);
              a.appendChild(draftBody);
            }
            draftBody!.textContent = stripThinking(acc);
          },
          onDone: (full) => {
            // The single gate: verified answer, or verified facts. Never a lie.
            const { text, verified } = guardedAnswer(cfg, q, full || acc);
            if (verified) {
              reveal(() => {
                commit(a, q, text, 'verified');
                history.push({ role: 'user', content: q }, { role: 'assistant', content: text });
              });
            } else {
              failOut('corrected');
            }
          },
          onError: () => failOut('corrected'),
        });
      };
      runAttempt(1);
    }

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      submit(input.value);
    });
    stopBtn.addEventListener('click', () => engine.stop());
  }
</script>

<!-- Global (not scoped): the thread/answer/badge/source nodes are created at
     runtime via createElement, which Astro's scoped styles don't reach. All
     selectors are unique .askp-* names, so there is no leakage. -->
<style is:global>
  #askpage { --a: var(--accent); }

  /* ——— Hero ——— */
  .askp-hero { position: relative; padding-top: 1.5rem; }
  @media (min-width: 768px) { .askp-hero { padding-top: 2.5rem; } }

  .askp-eyebrow {
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-size: 0.7rem; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--a);
  }
  .askp-eyebrow-dot {
    width: 6px; height: 6px; border-radius: 50%; background: var(--a);
    box-shadow: 0 0 0 0 color-mix(in srgb, var(--a) 60%, transparent);
    animation: askpPulse 2.4s ease-out infinite;
  }
  @keyframes askpPulse {
    0% { box-shadow: 0 0 0 0 color-mix(in srgb, var(--a) 55%, transparent); }
    70% { box-shadow: 0 0 0 7px transparent; }
    100% { box-shadow: 0 0 0 0 transparent; }
  }

  .askp-title {
    font-size: clamp(2.4rem, 6.5vw, 3.4rem); font-weight: 500; line-height: 1.12;
    letter-spacing: 0.005em; color: var(--ink); margin-top: 1rem;
  }
  .askp-lead {
    max-width: 40rem; margin-top: 1.1rem; color: var(--ink-secondary);
    font-size: 1.02rem; line-height: 1.8;
  }

  /* ——— Console (input) ——— */
  .askp-console {
    position: relative; display: flex; flex-direction: column; gap: 0.55rem;
    margin-top: 2rem; padding: 0.85rem 0.9rem;
    background: var(--surface); border: 1px solid var(--line-strong); border-radius: 16px;
    box-shadow: 0 1px 2px rgba(0,0,0,0.04), 0 18px 40px -28px rgba(0,0,0,0.4);
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .askp-console:focus-within {
    border-color: var(--a);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--a) 12%, transparent), 0 18px 40px -26px color-mix(in srgb, var(--a) 55%, transparent);
  }
  .askp-console-top { display: flex; align-items: flex-start; gap: 0.6rem; }
  .askp-mark {
    flex: none; display: flex; align-items: center; justify-content: center;
    width: 30px; height: 30px; margin-top: 1px; color: var(--a);
  }
  .askp-mark svg { width: 22px; height: 22px; }
  .askp-input {
    flex: 1; min-width: 0; resize: none; border: none; background: none; color: var(--ink);
    font-family: var(--font-body); font-size: 1.02rem; line-height: 1.6; max-height: 200px;
    padding: 4px 0; outline: none;
  }
  .askp-input::placeholder { color: var(--ink-muted); }

  /* composer footer: model tools (left) + actions (right) */
  .askp-console-foot { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; }
  .askp-tools { display: flex; align-items: center; gap: 0.4rem; flex-wrap: wrap; margin-right: auto; }
  .askp-tool {
    position: relative; display: inline-flex; align-items: center;
    border: 1px solid var(--line); border-radius: 999px; background: var(--paper);
    padding-left: 0.55rem; transition: border-color 0.15s ease, background 0.15s ease;
  }
  .askp-tool:hover { border-color: color-mix(in srgb, var(--a) 45%, var(--line-strong)); }
  .askp-tool:focus-within { border-color: var(--a); }
  .askp-tool-ico { display: flex; width: 15px; height: 15px; color: var(--a); flex: none; pointer-events: none; }
  .askp-tool-ico svg { width: 15px; height: 15px; }
  .askp-tool-select {
    appearance: none; border: none; background: none; color: var(--ink);
    font-family: var(--font-body); font-size: 0.78rem; font-weight: 500; cursor: pointer;
    padding: 0.34rem 1.5rem 0.34rem 0.4rem; outline: none; max-width: 15rem;
  }
  .askp-tool-chev { position: absolute; right: 0.55rem; width: 9px; height: 6px; color: var(--ink-muted); pointer-events: none; }
  .askp-actions { display: flex; align-items: center; gap: 0.4rem; align-self: flex-end; flex: none; }
  .askp-model-hint { margin-top: 0.55rem; font-size: 0.74rem; line-height: 1.55; color: var(--ink-muted); min-height: 1em; }

  .askp-send, .askp-stop {
    flex: none; display: inline-flex; align-items: center; justify-content: center;
    width: 38px; height: 38px; border-radius: 50%;
    cursor: pointer; transition: transform 0.12s ease, opacity 0.15s ease, background 0.15s ease;
  }
  .askp-send { border: 1px solid var(--a); background: var(--a); color: #fff; }
  :root.dark .askp-send { color: #0f1012; }
  .askp-send svg { width: 18px; height: 18px; }
  .askp-send:hover { transform: translateY(-1px); }
  .askp-send:active { transform: translateY(0); }
  .askp-stop { border: 1px solid var(--line-strong); background: transparent; color: var(--a); }
  .askp-stop svg { width: 15px; height: 15px; }

  /* ——— Under-bar: device + chips ——— */
  .askp-underbar {
    display: flex; flex-wrap: wrap; align-items: center; gap: 0.6rem 1rem; margin-top: 0.9rem;
  }
  .askp-device {
    display: inline-flex; align-items: center; gap: 0.4rem;
    font-size: 0.72rem; color: var(--ink-muted); letter-spacing: 0.02em;
  }
  .askp-device::before {
    content: ''; width: 5px; height: 5px; border-radius: 50%;
    background: var(--a); opacity: 0.8;
  }
  .askp-device.is-warn { color: #b4791f; }
  :root.dark .askp-device.is-warn { color: #d8a24a; }
  .askp-device.is-warn::before { background: #d8a24a; }

  .askp-chips { display: flex; flex-wrap: wrap; gap: 0.45rem; }
  .askp-chip {
    padding: 0.4rem 0.8rem; font-size: 0.78rem; color: var(--ink-secondary);
    background: var(--surface); border: 1px solid var(--line); border-radius: 999px; cursor: pointer;
    transition: border-color 0.15s ease, color 0.15s ease, transform 0.12s ease;
  }
  .askp-chip:hover { border-color: var(--a); color: var(--ink); transform: translateY(-1px); }

  /* ——— Loading ——— */
  .askp-load { margin-top: 1.2rem; max-width: 32rem; }
  .askp-load-bar { height: 4px; background: var(--line); border-radius: 999px; overflow: hidden; }
  .askp-load-bar span {
    display: block; height: 100%; width: 0%; border-radius: 999px;
    background: linear-gradient(90deg, color-mix(in srgb, var(--a) 55%, transparent), var(--a));
    transition: width 0.25s ease;
  }
  .askp-load-text { font-size: 0.74rem; color: var(--ink-muted); margin-top: 0.45rem; }
  .askp-hint { margin-top: 1rem; max-width: 38rem; font-size: 0.76rem; line-height: 1.6; color: var(--ink-muted); }

  .askp-badge.is-retrieval {
    background: color-mix(in srgb, var(--a) 7%, var(--surface));
    border-color: color-mix(in srgb, var(--a) 22%, var(--line));
  }
  .askp-badge.is-retrieval svg, .askp-badge.is-retrieval b { color: var(--a); }

  /* ——— Download confirmation ——— */
  .askp-confirm {
    display: flex; gap: 0.7rem; margin-top: 1.1rem; padding: 0.9rem 1rem;
    border-radius: 12px; border: 1px solid color-mix(in srgb, #b4791f 40%, var(--line));
    background: color-mix(in srgb, #b4791f 9%, var(--surface));
  }
  @media (prefers-reduced-motion: no-preference) { .askp-confirm:not([hidden]) { animation: askpRise 0.2s ease; } }
  .askp-confirm-ico { flex: none; color: #a06a15; margin-top: 1px; }
  :root.dark .askp-confirm-ico { color: #d8a24a; }
  .askp-confirm-ico svg { width: 20px; height: 20px; }
  .askp-confirm-body { flex: 1; min-width: 0; }
  .askp-confirm-title { font-size: 0.9rem; font-weight: 600; color: var(--ink); line-height: 1.5; }
  .askp-confirm-note { margin-top: 0.3rem; font-size: 0.76rem; line-height: 1.6; color: var(--ink-muted); }
  .askp-confirm-actions { display: flex; gap: 0.5rem; margin-top: 0.8rem; }
  .askp-confirm-go, .askp-confirm-cancel {
    padding: 0.42rem 1rem; border-radius: 8px; font-size: 0.83rem; font-weight: 500; cursor: pointer;
    transition: transform 0.12s ease, opacity 0.15s ease, background 0.15s ease;
  }
  .askp-confirm-go { border: 1px solid var(--a); background: var(--a); color: #fff; }
  :root.dark .askp-confirm-go { color: #0f1012; }
  .askp-confirm-go:hover { transform: translateY(-1px); }
  .askp-confirm-cancel { border: 1px solid var(--line-strong); background: transparent; color: var(--ink-secondary); }
  .askp-confirm-cancel:hover { color: var(--ink); }

  /* ——— Thread ——— */
  .askp-thread { margin-top: 2.75rem; display: flex; flex-direction: column; gap: 1.75rem; }
  .askp-qa { border-top: 1px solid var(--line); padding-top: 1.6rem; }
  @media (prefers-reduced-motion: no-preference) {
    .askp-qa { animation: askpRise 0.3s ease; }
    @keyframes askpRise { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: none; } }
  }
  .askp-q { font-size: 1.18rem; font-weight: 500; line-height: 1.5; color: var(--ink); }

  .askp-a { margin-top: 1rem; }
  .askp-a-body {
    font-size: 1rem; line-height: 1.9; color: var(--ink);
    white-space: pre-wrap; word-break: break-word;
  }
  .askp-a-body.is-draft { color: var(--ink-muted); }

  /* Résumé-facts answer: a short lead + a clean list of verified facts. */
  .askp-a-lead { font-size: 0.9rem; color: var(--ink-muted); margin-bottom: 0.75rem; }
  .askp-a-facts { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.7rem; }
  .askp-a-facts li {
    position: relative; padding-left: 1.15rem;
    font-size: 1rem; line-height: 1.75; color: var(--ink); word-break: break-word;
  }
  .askp-a-facts li::before {
    content: ''; position: absolute; left: 0; top: 0.62em;
    width: 6px; height: 6px; border-radius: 50%; background: var(--a);
  }

  .askp-draft { display: inline-flex; align-items: center; gap: 0.6rem; color: var(--ink-muted); }
  .askp-orb { display: inline-flex; width: 22px; height: 22px; color: var(--a); }
  .askp-orb svg { width: 22px; height: 22px; }
  @media (prefers-reduced-motion: no-preference) {
    .askp-orb { animation: askpFloat 1.6s ease-in-out infinite; }
    .askp-orb svg circle:last-child { transform-origin: center; animation: askpRing 1.6s ease-out infinite; }
    @keyframes askpFloat { 0%,100% { opacity: 0.7; } 50% { opacity: 1; } }
    @keyframes askpRing { 0% { transform: scale(0.7); opacity: 0.6; } 100% { transform: scale(1.15); opacity: 0; } }
  }
  .askp-draft-label { font-size: 0.9rem; }
  .askp-draft-tag {
    display: inline-block; font-size: 0.62rem; font-weight: 600; letter-spacing: 0.14em;
    text-transform: uppercase; color: var(--ink-muted); margin-bottom: 0.4rem;
  }

  /* ——— Verification badge ——— */
  .askp-badge {
    display: flex; align-items: flex-start; gap: 0.6rem; margin-top: 1rem;
    padding: 0.65rem 0.85rem; border-radius: 11px; border: 1px solid var(--line);
  }
  .askp-badge svg { width: 18px; height: 18px; flex: none; margin-top: 1px; }
  .askp-badge-txt { display: flex; flex-direction: column; gap: 0.15rem; }
  .askp-badge-txt b { font-size: 0.82rem; font-weight: 600; }
  .askp-badge-txt span { font-size: 0.75rem; line-height: 1.55; color: var(--ink-muted); }
  .askp-badge.is-verified {
    background: color-mix(in srgb, var(--a) 8%, var(--surface));
    border-color: color-mix(in srgb, var(--a) 30%, var(--line));
  }
  .askp-badge.is-verified svg, .askp-badge.is-verified b { color: var(--a); }
  .askp-badge.is-corrected {
    background: color-mix(in srgb, #b4791f 8%, var(--surface));
    border-color: color-mix(in srgb, #b4791f 28%, var(--line));
  }
  .askp-badge.is-corrected svg, .askp-badge.is-corrected b { color: #a06a15; }
  :root.dark .askp-badge.is-corrected svg, :root.dark .askp-badge.is-corrected b { color: #d8a24a; }

  /* ——— Sources ——— */
  .askp-sources { margin-top: 0.75rem; }
  .askp-sources-sum {
    display: inline-flex; align-items: center; gap: 0.45rem; cursor: pointer;
    font-size: 0.76rem; color: var(--ink-muted); list-style: none; user-select: none;
    padding: 0.35rem 0; transition: color 0.15s ease;
  }
  .askp-sources-sum:hover { color: var(--ink-secondary); }
  .askp-sources-sum::-webkit-details-marker { display: none; }
  .askp-sources-sum svg { width: 14px; height: 14px; }
  .askp-sources-n {
    font-variant-numeric: tabular-nums; font-size: 0.66rem; padding: 0.05rem 0.4rem;
    border: 1px solid var(--line); border-radius: 999px;
  }
  .askp-sources[open] .askp-sources-sum { color: var(--ink-secondary); }
  .askp-sources-list {
    margin-top: 0.4rem; display: flex; flex-direction: column; gap: 0.5rem;
    border-left: 2px solid color-mix(in srgb, var(--a) 35%, var(--line)); padding-left: 0.9rem;
  }
  .askp-source { font-size: 0.8rem; line-height: 1.65; color: var(--ink-muted); }

  /* ——— How it works ——— */
  .askp-how { margin-top: 4.5rem; padding-top: 2.25rem; border-top: 1px solid var(--line); }
  .askp-how-title { font-size: 1.5rem; font-weight: 600; color: var(--ink); }
  .askp-how-lead { margin-top: 0.5rem; color: var(--ink-muted); font-size: 0.9rem; }
  .askp-how-grid {
    margin-top: 1.75rem; display: grid; gap: 0.9rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 720px) { .askp-how-grid { grid-template-columns: repeat(3, 1fr); } }
  .askp-card {
    padding: 1.25rem; border: 1px solid var(--line); border-radius: 14px; background: var(--surface);
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .askp-card:hover { border-color: color-mix(in srgb, var(--a) 40%, var(--line)); transform: translateY(-2px); }
  .askp-card-ico {
    display: inline-flex; align-items: center; justify-content: center; width: 40px; height: 40px;
    border-radius: 11px; color: var(--a);
    background: color-mix(in srgb, var(--a) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--a) 22%, var(--line));
  }
  .askp-card-ico svg { width: 21px; height: 21px; }
  .askp-card-label {
    margin-top: 0.9rem; font-size: 0.66rem; font-weight: 600; letter-spacing: 0.16em;
    text-transform: uppercase; color: var(--ink-muted);
  }
  .askp-card-name { margin-top: 0.3rem; font-size: 1.02rem; font-weight: 600; color: var(--ink); }
  .askp-card-by { margin-top: 0.1rem; font-size: 0.76rem; color: var(--ink-muted); }
  .askp-card-desc { margin-top: 0.7rem; font-size: 0.86rem; line-height: 1.75; color: var(--ink-secondary); }
  .askp-stacknote {
    margin-top: 1.5rem; font-size: 0.74rem; color: var(--ink-muted); text-align: center;
    letter-spacing: 0.02em;
  }
</style>
