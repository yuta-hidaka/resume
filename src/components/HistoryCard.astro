---
interface Props {
  company: string;
  startDate: string;
  endDate: string;
  jobTitle: string;
  job: string;
  jobDescription: string;
  tags?: string[];
  index: number;
  locale: string;
}

const { company, startDate, endDate, jobTitle, job, jobDescription, tags, index, locale } = Astro.props;

function formatDate(dateStr: string, locale: string): string {
  if (!dateStr) return locale === 'ja' ? '現在' : 'Present';
  const date = new Date(dateStr);
  const year = date.getFullYear();
  const month = String(date.getMonth() + 1).padStart(2, '0');
  return `${year}.${month}`;
}

const formattedStartDate = formatDate(startDate, locale);
const formattedEndDate = formatDate(endDate, locale);
const labelMore = locale === 'ja' ? '続きを読む' : 'Read more';
const labelLess = locale === 'ja' ? '閉じる' : 'Show less';
const descId = `career-desc-${locale}-${index}`;
---

<article class="glass career-entry entry-grid">
  <p class="entry-dates tnum">
    {formattedStartDate} — {formattedEndDate}
  </p>

  <div class="min-w-0">
    <h2 class="entry-company font-display">{company}</h2>
    <p class="entry-role">
      <span class="font-medium text-[var(--ink-secondary)]">{jobTitle}</span>
      <span class="text-[var(--ink-muted)]"> · {job}</span>
    </p>

    <p class="entry-desc is-clamped" id={descId} data-career-desc>{jobDescription}</p>
    <button
      type="button"
      class="read-more"
      data-read-more
      data-label-more={labelMore}
      data-label-less={labelLess}
      aria-expanded="false"
      aria-controls={descId}
      hidden
    >{labelMore}</button>

    {tags && tags.length > 0 && (
      <p class="entry-tags">{tags.join('  ·  ')}</p>
    )}
  </div>
</article>

<script>
  const entries: Array<{ desc: HTMLElement; button: HTMLButtonElement }> = [];

  document.querySelectorAll<HTMLElement>('[data-career-desc]').forEach((desc) => {
    const button = desc.parentElement?.querySelector<HTMLButtonElement>('[data-read-more]');
    if (!button) return;
    entries.push({ desc, button });

    button.addEventListener('click', () => {
      const clamped = desc.classList.toggle('is-clamped');
      button.setAttribute('aria-expanded', String(!clamped));
      button.textContent = clamped
        ? button.dataset.labelMore ?? ''
        : button.dataset.labelLess ?? '';
    });
  });

  // Show the toggle only while the clamped text actually overflows.
  const measureAll = () => {
    entries.forEach(({ desc, button }) => {
      if (!desc.classList.contains('is-clamped')) return;
      button.hidden = desc.scrollHeight <= desc.clientHeight + 1;
    });
  };

  measureAll();
  if (document.fonts?.ready) {
    document.fonts.ready.then(measureAll).catch(() => {});
  }

  let resizeTimer: ReturnType<typeof setTimeout> | undefined;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(measureAll, 150);
  });
</script>

<style>
  .career-entry {
    padding: 1.9rem 1.75rem;
    margin-bottom: 1.5rem;
  }

  @media (min-width: 768px) {
    .career-entry {
      padding: 2.1rem 2.25rem;
    }
  }

  .entry-company {
    font-size: 1.35rem;
    font-weight: 600;
    line-height: 1.35;
    color: var(--ink);
  }

  .entry-role {
    margin-top: 0.25rem;
    font-size: 0.9rem;
  }

  .entry-desc {
    margin-top: 1rem;
    color: var(--ink-secondary);
  }

  .entry-desc.is-clamped {
    display: -webkit-box;
    -webkit-line-clamp: 5;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .read-more {
    margin-top: 0.6rem;
    padding: 0;
    border: none;
    background: none;
    font-size: 0.85rem;
    color: var(--accent);
    cursor: pointer;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.22em;
  }

  .read-more:hover {
    text-decoration-thickness: 1.5px;
  }

  .entry-tags {
    margin-top: 1.2rem;
    font-size: 0.78rem;
    line-height: 1.7;
    letter-spacing: 0.02em;
    color: var(--ink-muted);
  }
</style>
