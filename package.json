{
  "name": "portfolio",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.14",
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "node scripts/sync-doc-assets.mjs && astro dev",
    "build": "node scripts/sync-doc-assets.mjs && astro build",
    "preview": "astro preview",
    "generate:pdf": "node scripts/generate-static-pdfs.mjs",
    "astro": "astro",
    "test": "bun test src/lib/ask",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@sparticuz/chromium": "^149.0.0",
    "@tailwindcss/vite": "^4.3.2",
    "astro": "^7.0.7",
    "marked": "^17.0.6",
    "puppeteer-core": "^25.3.0",
    "tailwindcss": "^4.3.2",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/three": "^0.185.1"
  }
}
